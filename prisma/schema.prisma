generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id @default(cuid())
  title       String
  link        String   @unique
  publishedAt DateTime?
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())
}